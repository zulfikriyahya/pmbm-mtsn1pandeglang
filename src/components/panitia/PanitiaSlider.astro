import { useRef, useState, useEffect } from "react";
import { ChevronLeft, ChevronRight } from "lucide-react";
import { gsap } from "gsap";

interface Panitia {
  id: number;
  nama: string;
  foto: string;
  jabatan: string;
  deskripsi: string;
  wa: string;
  email: string;
}

function PanitiaCard({ p }: { p: Panitia }) {
  return (
    <div
      className="flex-shrink-0 w-52 flex flex-col items-center text-center rounded-2xl p-5 transition-all duration-300"
      style={{
        background: "#0D1F30",
        border:     "1px solid rgba(155,175,196,0.09)",
        boxShadow:  "0 2px 20px rgba(0,0,0,0.28)",
      }}
      onMouseEnter={(e) => {
        const el = e.currentTarget as HTMLElement;
        el.style.transform   = "translateY(-4px)";
        el.style.boxShadow   = "0 10px 40px rgba(0,0,0,0.44)";
        el.style.borderColor = "rgba(155,175,196,0.20)";
      }}
      onMouseLeave={(e) => {
        const el = e.currentTarget as HTMLElement;
        el.style.transform   = "";
        el.style.boxShadow   = "0 2px 20px rgba(0,0,0,0.28)";
        el.style.borderColor = "rgba(155,175,196,0.09)";
      }}
    >
      {/* Avatar circular */}
      <div
        className="w-20 h-20 rounded-full overflow-hidden mb-4 flex-shrink-0"
        style={{
          background:    "linear-gradient(135deg,#1E3A57,#2E567C)",
          outline:       "3px solid rgba(155,175,196,0.12)",
          outlineOffset: "2px",
        }}
      >
        {p.foto ? (
          <img
            src={p.foto}
            alt={p.nama}
            className="w-full h-full object-cover object-top"
            loading="lazy"
          />
        ) : (
          <div className="w-full h-full flex items-center justify-center font-bold text-2xl text-white">
            {p.nama.charAt(0)}
          </div>
        )}
      </div>

      {/* Badge jabatan */}
      <span
        className="inline-block text-[11px] font-semibold px-2.5 py-0.5 rounded-full mb-2"
        style={{
          background: "rgba(155,175,196,0.10)",
          color:      "#9AAFC4",
          border:     "1px solid rgba(155,175,196,0.14)",
        }}
      >
        {p.jabatan}
      </span>

      {/* Nama */}
      <h3 className="font-bold text-sm leading-snug" style={{ color: "#E8EDF3" }}>
        {p.nama}
      </h3>

      {/* Deskripsi */}
      {p.deskripsi && (
        <p className="text-[11px] leading-relaxed mt-1.5 line-clamp-2" style={{ color: "#6F8EAC" }}>
          {p.deskripsi}
        </p>
      )}

      {/* Kontak */}
      {(p.wa || p.email) && (
        <div className="flex gap-2 mt-3 flex-wrap justify-center">
          {p.wa && (
            <a
              href={`https://wa.me/${p.wa}`}
              target="_blank"
              rel="noopener noreferrer"
              className="text-[11px] font-medium px-2.5 py-1 rounded-full transition-colors"
              style={{
                background: "rgba(155,175,196,0.08)",
                color:      "#9AAFC4",
                border:     "1px solid rgba(155,175,196,0.12)",
              }}
              onMouseEnter={(e) => {
                (e.currentTarget as HTMLElement).style.background = "rgba(155,175,196,0.15)";
                (e.currentTarget as HTMLElement).style.color = "#C5D0DC";
              }}
              onMouseLeave={(e) => {
                (e.currentTarget as HTMLElement).style.background = "rgba(155,175,196,0.08)";
                (e.currentTarget as HTMLElement).style.color = "#9AAFC4";
              }}
            >
              WhatsApp
            </a>
          )}
          {p.email && (
            <a
              href={`mailto:${p.email}`}
              className="text-[11px] font-medium px-2.5 py-1 rounded-full transition-colors"
              style={{
                background: "rgba(155,175,196,0.08)",
                color:      "#9AAFC4",
                border:     "1px solid rgba(155,175,196,0.12)",
              }}
              onMouseEnter={(e) => {
                (e.currentTarget as HTMLElement).style.background = "rgba(155,175,196,0.15)";
                (e.currentTarget as HTMLElement).style.color = "#C5D0DC";
              }}
              onMouseLeave={(e) => {
                (e.currentTarget as HTMLElement).style.background = "rgba(155,175,196,0.08)";
                (e.currentTarget as HTMLElement).style.color = "#9AAFC4";
              }}
            >
              Email
            </a>
          )}
        </div>
      )}
    </div>
  );
}

export default function PanitiaSlider({ panitia }: { panitia: Panitia[] }) {
  const trackRef              = useRef<HTMLDivElement>(null);
  const [idx, setIdx]         = useState(0);
  const [visible, setVisible] = useState(4);

  const CARD_W = 224; // 208px + 16px gap

  useEffect(() => {
    const update = () => {
      const w = window.innerWidth;
      setVisible(w < 640 ? 1 : w < 768 ? 2 : w < 1024 ? 3 : 4);
    };
    update();
    window.addEventListener("resize", update);
    return () => window.removeEventListener("resize", update);
  }, []);

  const maxIdx   = Math.max(0, panitia.length - visible);
  const canLeft  = idx > 0;
  const canRight = idx < maxIdx;

  const slideTo = (next: number) => {
    const n = Math.max(0, Math.min(next, maxIdx));
    setIdx(n);
    gsap.to(trackRef.current, {
      x: -n * CARD_W,
      duration: 0.45,
      ease: "power3.out",
    });
  };

  useEffect(() => {
    const clamped = Math.min(idx, maxIdx);
    if (clamped !== idx) setIdx(clamped);
    gsap.set(trackRef.current, { x: -clamped * CARD_W });
  }, [visible]);

  const dots = maxIdx + 1;

  return (
    <div>
      {/* Viewport */}
      <div className="relative overflow-hidden">
        <div
          className="absolute left-0 top-0 bottom-0 w-10 z-10 pointer-events-none transition-opacity duration-300"
          style={{
            background: "linear-gradient(to right,#07121C,transparent)",
            opacity: canLeft ? 1 : 0,
          }}
        />
        <div
          className="absolute right-0 top-0 bottom-0 w-10 z-10 pointer-events-none transition-opacity duration-300"
          style={{
            background: "linear-gradient(to left,#07121C,transparent)",
            opacity: canRight ? 1 : 0,
          }}
        />

        <div ref={trackRef} className="flex gap-4 w-max py-2">
          {panitia.map((p) => (
            <PanitiaCard key={p.id} p={p} />
          ))}
        </div>
      </div>

      {/* Controls */}
      <div className="flex items-center justify-between mt-6">
        <div className="flex gap-1.5 items-center">
          {Array.from({ length: dots }).map((_, i) => (
            <button
              key={i}
              onClick={() => slideTo(i)}
              className="rounded-full transition-all duration-300"
              style={{
                width:      i === idx ? "20px" : "6px",
                height:     "6px",
                background: i === idx
                  ? "linear-gradient(135deg,#1E3A57,#2E567C)"
                  : "rgba(155,175,196,0.20)",
              }}
              aria-label={`Slide ${i + 1}`}
            />
          ))}
        </div>

        <div className="flex gap-2">
          <button
            onClick={() => slideTo(idx - 1)}
            disabled={!canLeft}
            className="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200"
            style={{
              background: canLeft ? "rgba(155,175,196,0.10)" : "rgba(155,175,196,0.04)",
              border:     "1px solid " + (canLeft ? "rgba(155,175,196,0.18)" : "rgba(155,175,196,0.07)"),
              color:      canLeft ? "#9AAFC4" : "rgba(155,175,196,0.20)",
              cursor:     canLeft ? "pointer" : "not-allowed",
            }}
          >
            <ChevronLeft size={16} />
          </button>
          <button
            onClick={() => slideTo(idx + 1)}
            disabled={!canRight}
            className="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200"
            style={{
              background: canRight ? "rgba(155,175,196,0.10)" : "rgba(155,175,196,0.04)",
              border:     "1px solid " + (canRight ? "rgba(155,175,196,0.18)" : "rgba(155,175,196,0.07)"),
              color:      canRight ? "#9AAFC4" : "rgba(155,175,196,0.20)",
              cursor:     canRight ? "pointer" : "not-allowed",
            }}
          >
            <ChevronRight size={16} />
          </button>
        </div>
      </div>
    </div>
  );
}
