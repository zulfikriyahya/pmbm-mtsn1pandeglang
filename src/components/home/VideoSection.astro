---
import { SITE } from "@config/site";
---

<section class="py-24" style="background:#0A1828;">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="eyebrow">Selayang Pandang</span>
        <h2 class="section-title mt-3 mb-4">Mengenal {SITE.shortName}</h2>
        <p class="leading-relaxed" style="color:#6F8EAC;">
          Inkubator Generasi Cendekia &amp; Berkarakter. Kami menyatukan tradisi keilmuan dengan
          kemuliaan adab — merajut kecerdasan intelektual, kematangan spiritual, dan kepekaan sosial
          dalam satu sinergi yang harmonis.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            ["Mandiri", "Takwa", "Peduli Lingkungan", "Prestasi"].map((p) => (
              <span
                class="text-xs font-semibold px-3 py-1.5 rounded-full"
                style="background:rgba(155,175,196,0.09);color:#9AAFC4;border:1px solid rgba(155,175,196,0.14);"
              >
                {p}
              </span>
            ))
          }
        </div>
        <a
          href={SITE.mainUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 mt-7 text-sm font-semibold transition-all hover:gap-3"
          style="color:#9AAFC4;"
          onmouseover="this.style.color='#C5D0DC'"
          onmouseout="this.style.color='#9AAFC4'"
        >
          Kunjungi Website Resmi <span>→</span>
        </a>
      </div>

      <div
        class="aspect-video rounded-2xl overflow-hidden"
        style="border:1px solid rgba(155,175,196,0.09);box-shadow:0 8px 40px rgba(0,0,0,0.40);"
      >
        <iframe
          class="w-full h-full"
          src={`https://www.youtube-nocookie.com/embed/${SITE.youtubeId}?rel=0&modestbranding=1`}
          title={`Selayang Pandang ${SITE.shortName}`}
          allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"
          allowfullscreen
          loading="lazy"></iframe>
      </div>
    </div>
  </div>
</section>
