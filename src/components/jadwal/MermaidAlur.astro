<section class="py-20" style="background:#0A1828;">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <span class="eyebrow justify-center">Diagram Alur</span>
      <h2 class="section-title mt-3">Alur Pendaftaran</h2>
    </div>

    <div
      class="rounded-2xl p-6 sm:p-10 overflow-x-auto"
      style="background:#0D1F30;border:1px solid rgba(155,175,196,0.09);box-shadow:0 2px 20px rgba(0,0,0,0.32);"
    >
      <div id="mermaid-diagram" class="flex justify-center"></div>
    </div>
  </div>
</section>

<script type="module" is:inline>
  import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";

  mermaid.initialize({
    startOnLoad: false,
    theme: "base",
    themeVariables: {
      background: "#0D1F30",
      primaryColor: "#152D45",
      primaryTextColor: "#C5D0DC",
      primaryBorderColor: "#2E567C",
      secondaryColor: "#0D1F30",
      tertiaryColor: "#0D1F30",
      lineColor: "#4E7294",
      edgeLabelBackground: "#0D1F30",
      fontFamily: "Lexend, sans-serif",
      fontSize: "14px",
    },
  });

  const diagram = `flowchart TD
    A([Calon Peserta Didik]) --> B[Akses pmbm-kanwilbanten.com]
    B --> C[Isi Formulir Pendaftaran Online]
    C --> D[Upload Berkas Persyaratan]
    D --> E{Verifikasi Panitia}
    E -->|Lengkap| F[Cetak Kartu Peserta]
    E -->|Tidak Lengkap| D
    F --> G[Ikuti Tes Seleksi CAT dan BTQ]
    G --> H{Pengumuman Hasil}
    H -->|Diterima| I[Lapor Diri dan Pemberkasan]
    H -->|Tidak Diterima| J([Selesai])
    I --> K([Peserta Didik Baru MTsN 1 Pandeglang])
    style A fill:#1E3A57,color:#E8EDF3,stroke:#2E567C,stroke-width:2px
    style K fill:#152D45,color:#E8EDF3,stroke:#2E567C,stroke-width:2px
    style E fill:#92680a,color:#fff,stroke:none
    style H fill:#92680a,color:#fff,stroke:none`;

  const el = document.getElementById("mermaid-diagram");
  if (el) {
    const { svg } = await mermaid.render("mermaid-svg", diagram);
    el.innerHTML = svg;
    // pastikan SVG mengisi lebar container dengan baik
    const svgEl = el.querySelector("svg");
    if (svgEl) {
      svgEl.style.maxWidth = "100%";
      svgEl.style.height = "auto";
    }
  }
</script>
