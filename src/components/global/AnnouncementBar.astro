---
import { SITE } from "@config/site";
---

<div
  id="ann-bar"
  class="relative overflow-hidden text-white text-xs py-2 px-4 no-print"
  style="background:linear-gradient(90deg,#030A11,#07121C 40%,#0D1F30);border-bottom:1px solid rgba(155,175,196,0.06);"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
    <div class="overflow-hidden flex-1">
      <p
        class="whitespace-nowrap font-medium animate-marquee"
        style="color:rgba(155,175,196,0.60);"
      >
        <span style="color:rgba(155,175,196,0.30);">◆</span>&nbsp;&nbsp;{SITE.announcement}
      </p>
    </div>
    <button
      id="ann-close"
      aria-label="Tutup"
      class="flex-shrink-0 w-5 h-5 flex items-center justify-center rounded-full transition-colors text-base leading-none"
      style="color:rgba(155,175,196,0.25);"
      onmouseover="this.style.color='rgba(155,175,196,0.70)';this.style.background='rgba(155,175,196,0.08)';"
      onmouseout="this.style.color='rgba(155,175,196,0.25)';this.style.background='';">×</button
    >
  </div>
</div>

<script>
  const bar = document.getElementById("ann-bar");
  const btn = document.getElementById("ann-close");
  if (sessionStorage.getItem("ann")) bar?.remove();
  btn?.addEventListener("click", () => {
    bar?.remove();
    sessionStorage.setItem("ann", "1");
  });
</script>
